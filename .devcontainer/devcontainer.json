{
  "name": "structural-coherence",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/astral-sh/devcontainer-features/uv:latest": {}
  },
  "postCreateCommand": "cd experiments/RFC-002-semantic-layer-text-to-sql && uv sync",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "experiments/RFC-002-semantic-layer-text-to-sql/.venv/bin/python",
        "ruff.path": ["experiments/RFC-002-semantic-layer-text-to-sql/.venv/bin/ruff"]
      }
    }
  }
}
