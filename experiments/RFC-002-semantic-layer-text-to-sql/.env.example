# RFC-002 environment variables
# Copy this file to .env and fill in values as needed.

# ── Current skeleton: no variables required ──────────────────────────
# The package is a tooling skeleton only (no pipeline logic yet).
# Everything below is placeholder for when RFC-002 is frozen and
# implementation begins.

# ── LLM provider keys (populate once the llm optional-dependency group
#    is populated in pyproject.toml) ──────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Database connection (populate once the db optional-dependency group
#    is populated in pyproject.toml) ──────────────────────────────────
# DATABASE_URL=
